      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "pythonNative",
        "pythonCode": "import subprocess\nimport json\nimport sys\nfrom pathlib import Path\nfrom datetime import datetime, timedelta\n\nscript_path = Path.home() / \".openclaw\" / \"workspace\" / \"scripts\" / \"memory-consolidator.py\"\nresult = subprocess.run([sys.executable, str(script_path)], capture_output=True, text=True)\noutput = result.stdout or \"\"\nlines = output.strip().split(\"\\n\") if output else []\nsummary_lines = [line.strip() for line in lines if \"Processing:\" in line or \"Archived:\" in line or \"updated\" in line.lower()]\ndate_str = (datetime.now() - timedelta(days=1)).strftime(\"%Y-%m-%d\")\nreturn {\"date\": date_str, \"success\": result.returncode == 0, \"files_archived\": sum(1 for l in lines if \"Archived:\" in l), \"insights_extracted\": \"Research summaries:\" in output, \"summary\": \"\\n\".join(summary_lines[-5:]) if summary_lines else \"Consolidation complete\"}"
      },
      "name": "Run Consolidator",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        0
      ]
    },
    {
