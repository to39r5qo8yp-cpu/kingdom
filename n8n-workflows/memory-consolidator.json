        "content": "={{ \"\ud83d\udcca **Memory Consolidator**\\n\\n\" + \"\ud83d\udcc5 \" + $json.date + \"\\n\\n\" + \"\u2705 Files archived: \" + String($json.files_archived) + \"\\n\" + \"\ud83d\udcdd Insights: \" + ($json.insights_extracted ? \"Extracted\" : \"None\") + \"\\n\\n\" + ($json.summary || \"Complete\") }}"
      },
