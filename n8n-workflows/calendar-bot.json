    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nif (!staticData.lastMessageId) staticData.lastMessageId = '0';\n\nconst messages = $input.all().map(item => item.json);\n\n// Filter to only messages newer than lastMessageId\nconst newMessages = messages.filter(m => m.id && BigInt(m.id) > BigInt(staticData.lastMessageId));\n\nif (newMessages.length === 0) return [];\n\n// Update lastMessageId to the newest\nconst newestId = newMessages.reduce((max, m) => BigInt(m.id) > BigInt(max) ? m.id : max, staticData.lastMessageId);\nstaticData.lastMessageId = newestId;\n\n// Return oldest first\nreturn newMessages.reverse().map(m => ({ json: m }));"
      },
      "id": "code-filter-new",
      "name": "Filter New Messages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        400
      ]
    },
