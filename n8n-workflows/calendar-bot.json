    {
      "parameters": {
        "jsCode": "const { title, date, time, allDay } = $json;\nconst isAllDay = allDay === true || !time;\n\nlet start, end;\nif (isAllDay) {\n  start = { date };\n  end = { date };\n} else {\n  const startISO = `${date}T${time}:00Z`;\n  const endISO = new Date(new Date(startISO).getTime() + 3600000).toISOString();\n  start = { dateTime: startISO, timeZone: 'UTC' };\n  end = { dateTime: endISO, timeZone: 'UTC' };\n}\n\nreturn [{ json: { ...$json, start, end, isAllDay } }];"
      },
