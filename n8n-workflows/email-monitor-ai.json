    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst subject = item.subject || item.Subject || '(no subject)';\nconst from    = item.from?.value?.[0]?.address || item.from || item.From || 'unknown';\nconst body    = item.text || item.snippet || item.body || '';\nconst date    = item.date || item.Date || new Date().toISOString();\nconst uid     = item.uid || item.id || item.messageId || '';\n\n// Parse date for display\nconst emailDate = new Date(date);\nconst timestamp = emailDate.toLocaleString('en-US', {\n  month: 'short', day: 'numeric',\n  hour: '2-digit', minute: '2-digit'\n});\n\nconst trimmedBody = body.substring(0, 2000);\n\n// Build chatInput with timestamp context\nconst chatInput = `Analyze this email:\n\nFrom: ${from}\nSubject: ${subject}\nDate: ${date}\n\nBody:\n${trimmedBody}`;\n\nreturn [{ json: { subject, from, body: trimmedBody, chatInput, timestamp, uid } }];"
      },
      "name": "Prepare Email Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        160,
        -16
      ],
      "id": "prepare-email-node"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.chatInput }}",
        "options": {
          "systemMessage": "You are an email triage assistant. Analyze the email and respond with ONLY valid JSON \u2014 no markdown, no explanation, no code blocks.\n\nStandard format (all categories except SHIPPED):\n{\"category\": \"URGENT|MEETING|FINANCE|SHIPPING|NEWSLETTER|SPAM|GENERAL\", \"summary\": \"one sentence max\", \"priority\": \"high|medium|low\"}\n\nSHIPPED format (use ONLY when an order has just been dispatched by a retailer):\n{\"category\": \"SHIPPED\", \"summary\": \"one sentence max\", \"priority\": \"medium\", \"item\": \"product name/description\", \"quantity\": \"number shipped\", \"tracking_number\": \"tracking ID or null\", \"order_number\": \"order ID or null\"}\n\nCategories:\n- URGENT: action required, deadlines, security alerts, password resets\n- MEETING: calendar invites, scheduling requests, appointment confirmations\n- FINANCE: receipts, invoices, orders, bank alerts, payment confirmations\n- SHIPPING: package tracking, delivery updates, carrier scan events (not the initial dispatch notification)\n- SHIPPED: initial \"your order has shipped\" notification from a retailer \u2014 extract item, quantity, tracking_number, order_number\n- NEWSLETTER: marketing, subscriptions, promotions, announcements\n- SPAM: unsolicited, phishing, junk, suspicious\n- GENERAL: everything else\n\nRespond with ONLY the JSON object."
        }
      },
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        320,
        -16
      ],
      "id": "ai-agent-node"
    },
    {
      "parameters": {
        "options": {
          "temperature": 0.1
        },
        "model": "llama3.2"
      },
      "name": "Ollama Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        320,
        176
      ],
      "id": "ollama-model-node",
      "credentials": {
        "ollamaApi": {
          "id": "dCTVfWIVTHlRhGsF",
          "name": "Ollama account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.output || $json.text || '{}';\nlet parsed = {};\n\n// Try to parse AI response\ntry {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(match ? match[0] : raw);\n} catch (e) {\n  // On parse failure, default to GENERAL with note\n  parsed = {\n    category: 'GENERAL',\n    summary: '(AI parse failed) ' + raw.substring(0, 100),\n    priority: 'low',\n    parseError: true\n  };\n}\n\nconst validCategories = ['URGENT', 'MEETING', 'FINANCE', 'SHIPPING', 'SHIPPED', 'NEWSLETTER', 'SPAM', 'GENERAL'];\nconst category = validCategories.includes(parsed.category) ? parsed.category : 'GENERAL';\nconst skipCategories = ['NEWSLETTER'];\n\nif (skipCategories.includes(category)) return [];\n\n// Get context from Prepare Email Data node\nconst emailData = $('Prepare Email Data').first().json;\n\nreturn [{ json: {\n  from:            emailData.from || 'unknown',\n  subject:         emailData.subject || '',\n  timestamp:       emailData.timestamp || '',\n  uid:             emailData.uid || '',\n  category,\n  summary:         parsed.summary || '',\n  priority:        parsed.priority || 'low',\n  parseError:      parsed.parseError || false,\n  item:            parsed.item || null,\n  quantity:        parsed.quantity || null,\n  tracking_number: parsed.tracking_number || null,\n  order_number:    parsed.order_number || null\n}}];"
      },
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        608,
        -16
      ],
      "id": "parse-ai-response-node"
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.category }}",
        "rules": {
          "rules": [
