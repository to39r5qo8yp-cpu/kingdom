    {
      "parameters": {
        "jsCode": "const { from, subject, summary, priority, timestamp, parseError } = $json;\nconst priorityIcon = priority === 'high' ? '\ud83d\udd34' : priority === 'medium' ? '\ud83d\udfe1' : '\ud83d\udfe2';\nconst errorNote = parseError ? ' \u26a0\ufe0f *AI parse failed*' : '';\nreturn [{ json: { message: `\ud83d\udea8 **URGENT** ${priorityIcon} ${priority.toUpperCase()}${errorNote}\n**From:** ${from}\n**Time:** ${timestamp}\n**Subject:** ${subject}\n**Summary:** ${summary}` } }];"
      },
