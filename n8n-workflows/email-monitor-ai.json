        "id": "gmail-mark-read-node",
        "name": "Mark As Read",
        "type": "n8n-nodes-base.gmail",
        "typeVersion": 2.1,
        "position": [
          160,
          -240
        ],
        "webhookId": "dd23b3e5-c10f-409f-9ade-f8f8698b4c40",
        "credentials": {
          "gmailOAuth2": {
